# Copy this file to `.env` (gitignored) and fill in real values.
# The bare-metal install path (bin/deploy-local.sh) and the container
# path (docker compose up) both source .env. Any value below can be
# overridden per-deploy by exporting it in the shell before invoking
# the install script / docker compose.

# PostgreSQL
POSTGRES_DB=wikantik
POSTGRES_USER=wikantik
# REQUIRED. deploy-local.sh refuses to run if this is unset or still
# the literal string "CHANGEME" — the safety guard is what stops a
# Tomcat ROOT.xml getting materialised with a known default credential.
POSTGRES_PASSWORD=CHANGEME
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Wikantik
WIKANTIK_BASE_URL=http://localhost:8080/
WIKANTIK_PAGE_DIR=/var/wikantik/pages
WIKANTIK_WORK_DIR=/var/wikantik/work
WIKANTIK_ATTACHMENT_DIR=/var/wikantik/pages

# MCP
MCP_USERS=curator
MCP_RATE_LIMIT_GLOBAL=100
MCP_RATE_LIMIT_PER_CLIENT=10

# Single Sign-On (OIDC, e.g. Google). Off unless WIKANTIK_SSO_ENABLED=true.
# redirect_uri registered with the provider = WIKANTIK_BASE_URL + /sso/callback
# (so WIKANTIK_BASE_URL must be the public https origin).
WIKANTIK_SSO_ENABLED=false
WIKANTIK_SSO_TYPE=oidc
WIKANTIK_SSO_OIDC_DISCOVERY_URI=https://accounts.google.com/.well-known/openid-configuration
WIKANTIK_SSO_OIDC_CLIENT_ID=
WIKANTIK_SSO_OIDC_CLIENT_SECRET=
WIKANTIK_SSO_OIDC_SCOPE=openid profile email
WIKANTIK_SSO_IDENTITY_CLAIM=sub
WIKANTIK_SSO_AUTO_PROVISION=true
# Claim mappings. Google sends no preferred_username, so map the login name to
# email; display name comes from the "name" claim.
WIKANTIK_SSO_CLAIM_LOGIN_NAME=email
WIKANTIK_SSO_CLAIM_FULL_NAME=name
WIKANTIK_SSO_CLAIM_EMAIL=email

# SMTP (Brevo)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_ACCOUNT=
MAIL_SMTP_PASSWORD=
MAIL_FROM=

# Backup
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=./backups
# Prometheus textfile metrics. The backup sidecar writes *.prom to
# BACKUP_METRICS_DIR (inside the container); docker-compose.prod.yml mounts the
# host's jakemon textfile-collector dir (BACKUP_TEXTFILE_DIR) there so the
# per-host Alloy agent scrapes the backup gauges. Defaults suit the docker1 +
# jakemon layout; override only if relocating either side.
BACKUP_METRICS_DIR=/textfile
BACKUP_TEXTFILE_DIR=/var/lib/jakemon/textfile

# Container DB host-port publishing. docker-compose.prod.yml publishes
# PostgreSQL on this address so the jakemon monitoring agent can reach it
# via host.docker.internal:5432. Defaults to the docker0 bridge gateway,
# which keeps the DB off the LAN. Set to 0.0.0.0 only to expose it
# LAN-wide. DB_EXPORTER_PASSWORD (in the gitignored .env.prod) stays —
# migration V031 uses it to give the wikantik_exporter role LOGIN for
# that agent.
DB_HOST_BIND=172.17.0.1

# ============================================================================
# Performance / search backend tuning (optional — all have safe defaults).
# Each value below maps to a wikantik.* property the container entrypoint
# injects into wikantik-custom.properties when set. Leaving them blank
# falls back to the baked-in ini defaults.
# ============================================================================

# Dense retrieval backend. inmemory (default) is best on a single-host
# deploy. Flip to pgvector once you split the DB to its own host so the
# HNSW lookup runs in PG and the app tier becomes stateless w.r.t. the
# vector index. Requires V032 + the one-shot backfill at
# bin/db/one-shots/2026-05-20-backfill-chunk-embeddings.sh first.
#   Spec: docs/superpowers/specs/2026-05-20-pgvector-hnsw-dense-retrieval-design.md
#WIKANTIK_DENSE_BACKEND=inmemory
#WIKANTIK_DENSE_EF_SEARCH=100

# Lucene Directory backend. nio (default) wins on this hardware — at our
# scale the OS page cache already serves all Lucene reads. mmap adds Java
# 21's MemorySession.checkValidStateRaw per-access overhead under high
# concurrency without a measurable I/O benefit. Keep as nio unless you
# have I/O pressure (large corpus that doesn't fit in page cache).
#WIKANTIK_LUCENE_DIRECTORY=nio

# VersioningFileProvider page-properties cache size. Default 100 was small
# for the typical corpus (12K+ pages); 5000 holds the typical working set
# entirely in memory with ~5 MB heap cost. Set to 0 for single-entry
# caching, -1 to disable caching entirely.
#WIKANTIK_VERSIONING_CACHE_SIZE=5000

# Maximum concurrent in-flight HTTP requests before BackpressureFilter
# returns 503 + Retry-After:1. Default 390 — it MUST sit below the Tomcat
# connector's maxThreads (400) or the cap can never be reached and the filter
# never fires. Set 0 or negative to disable backpressure entirely
# (pass-through). /api/health and /metrics bypass the filter and are NEVER
# rejected.
# Counter: wikantik_backpressure.rejected_total — how often the cap fires.
# Gauge:   wikantik_backpressure.inflight — current permit-holders.
#WIKANTIK_MAX_INFLIGHT_REQUESTS=390
