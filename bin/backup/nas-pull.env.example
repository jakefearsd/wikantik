# nas-pull.env — copy to nas-pull.env on the NAS and edit. Sourced by nas-pull.sh.
#
# --- Required: source (docker1) ---
DOCKER1_HOST=docker1
DOCKER1_USER=backup-reader
DOCKER1_BACKUP_DIR=/home/jakefear/wikantik/backups   # the rrsync-locked root on docker1 (documentary)
SSH_KEY=/config/nas-backup-key          # read-only key installed on docker1
# Source path RELATIVE to the rrsync-locked root. Leave empty for the
# recommended rrsync key (pulls the whole locked dir). For a full-shell
# account instead, set this to the absolute DOCKER1_BACKUP_DIR.
REMOTE_SRC_PATH=

# --- Required: destination (NAS) ---
NAS_DEST=/volume1/wikantik-backups       # dedicated subvolume/share on the NAS

# --- NAS-side retention (days). Longer tail than docker1. ---
NAS_RETAIN_DAILY_DAYS=90
NAS_RETAIN_WEEKLY_DAYS=183               # ~6 months
NAS_RETAIN_MONTHLY_DAYS=365              # ~1 year

# --- Off-box heartbeat ---
# Primary (recommended): write a Prometheus textfile that the NAS's local
# jakemon Alloy agent scrapes. Must match the agent's textfile-collector dir
# (jakemon agent/config.alloy reads /host/var/lib/jakemon/textfile, i.e. this
# host path). Emits wikantik_backup_offsite_{last_success,last_run}_timestamp_seconds
# and wikantik_backup_offsite_last_exit_status.
TEXTFILE_DIR=/var/lib/jakemon/textfile

# Optional remote push instead of / in addition to the textfile (Loki wins if
# both are set). Leave both empty to rely solely on the textfile heartbeat.
LOKI_URL=
PUSHGATEWAY_URL=
