<ruleset name="wikantik"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                             https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        Wikantik PMD ruleset: keeps high-signal bug / API-misuse / perf rules
        and drops style/complexity noise. Favors exposure — excluded rules are
        only the ones that fire constantly on this codebase with little payoff.
        See docs at https://pmd.github.io/pmd/pmd_rules_java.html
    </description>

    <!-- ================================================================ -->
    <!-- errorprone — real bug classes: resource leaks, broken null checks,
         exception handling mistakes, switch/serialization hazards.         -->
    <!-- ================================================================ -->
    <rule ref="category/java/errorprone.xml">
        <!-- Pure noise on a codebase this size: -->
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="AvoidFieldNameMatchingTypeName"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="NullAssignment"/>
        <!-- Fires on every servlet/filter inner class that's trivially serializable. -->
        <exclude name="NonSerializableClass"/>
        <!-- Theoretical; rarely a real bug, high false-positive rate. -->
        <exclude name="ConstructorCallsOverridableMethod"/>
        <!-- Deprecated / superseded. -->
        <exclude name="EmptyStatementNotInLoop"/>
        <!-- Beans/DTOs legitimately want mutable fields. -->
        <exclude name="DataflowAnomalyAnalysis"/>
        <!-- Fires on idiomatic `while ((line = reader.readLine()) != null)`,
             `ps.setString(idx++, ...)`, and `while ((n = in.read(buf)) > 0)` patterns
             used throughout the tree. ~47 sites, almost all legitimate. -->
        <exclude name="AssignmentInOperand"/>
        <!-- Legacy java.util.Date is baked into public APIs (UserProfile, PageLock,
             ArticleSummary) and JDBC column types. A full migration to java.time is
             a separate API-breaking project, not a cleanup sweep — ~128 sites across
             50 files. Suppress until scheduled. -->
        <exclude name="ReplaceJavaUtilDate"/>
        <!-- Same rationale as ReplaceJavaUtilDate — Calendar is used alongside Date
             in the same legacy code paths. -->
        <exclude name="ReplaceJavaUtilCalendar"/>
    </rule>

    <!-- EmptyCatchBlock: enforce project rule (log, don't swallow) but
         allow "ignored" / "expected" variable names to mark intentional drops. -->
    <rule ref="category/java/errorprone.xml/EmptyCatchBlock">
        <properties>
            <property name="allowCommentedBlocks" value="true"/>
            <property name="allowExceptionNameRegex">
                <value>^(ignored|expected)$</value>
            </property>
        </properties>
    </rule>

    <!-- ================================================================ -->
    <!-- bestpractices — unused code, stack-trace preservation, try-with-
         resources, Locale sanity, logging format strings, etc.             -->
    <!-- ================================================================ -->
    <rule ref="category/java/bestpractices.xml">
        <!-- Interface / servlet-override false positives. -->
        <exclude name="UnusedFormalParameter"/>
        <!-- Flags legitimate uses of ConcurrentHashMap/ConcurrentLinkedDeque/TreeSet/
             LinkedHashMap where the concrete type carries meaningful semantics
             (thread-safety, ordering, insertion order). The ArrayList/HashMap cases
             are mostly local-variable declarations where the concrete type is fine.
             ~75 sites, low signal. -->
        <exclude name="LooseCoupling"/>
        <!-- Log4j2 parameterized logging already handles this; rule fires on
             every LOG.debug("x {}", arg) call that PMD can't parse. -->
        <exclude name="GuardLogStatement"/>
        <!-- Test-style rules — turn on once we have budget for it.
             Names below are the PMD 7 spellings (Unit*, not JUnit*). -->
        <exclude name="UnitTestContainsTooManyAsserts"/>
        <exclude name="UnitTestShouldIncludeAssert"/>
        <exclude name="UnitTestAssertionsShouldIncludeMessage"/>
        <exclude name="UnitTestShouldUseTestAnnotation"/>
        <exclude name="UnitTestShouldUseBeforeAnnotation"/>
        <exclude name="UnitTestShouldUseAfterAnnotation"/>
        <!-- Very noisy; subclasses override protected members across the tree. -->
        <exclude name="AccessorClassGeneration"/>
        <exclude name="AccessorMethodGeneration"/>
        <!-- Android-only. -->
        <exclude name="AvoidReassigningLoopVariables"/>
    </rule>

    <!-- ================================================================ -->
    <!-- performance — autobox / wrapper instantiation, StringBuffer abuse,
         Files vs FileInputStream, redundant toString, etc.                 -->
    <!-- ================================================================ -->
    <rule ref="category/java/performance.xml">
        <!-- Famously noisy; nearly every loop allocates something. -->
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
        <!-- Style nit, not a perf issue. -->
        <exclude name="TooFewBranchesForSwitch"/>
        <!-- StringBuilder micro-perf rules: ~330 sites across the tree, all
             marginal (modern JIT elides the allocations these flag). Keep the
             signal rule (AppendCharacterWithChar — cheap char vs string) and
             drop the multi-line chain/capacity rules that generate yellow-sea
             reports with no measurable gain. -->
        <exclude name="ConsecutiveAppendsShouldReuse"/>
        <exclude name="ConsecutiveLiteralAppends"/>
        <exclude name="InsufficientStringBufferDeclaration"/>
    </rule>

    <!-- ================================================================ -->
    <!-- design — cherry-pick a handful of real structural smells, skip the
         complexity/metrics rules that just produce yellow-sea reports.     -->
    <!-- ================================================================ -->
    <rule ref="category/java/design.xml/SimplifyBooleanExpressions"/>
    <rule ref="category/java/design.xml/SimplifyBooleanReturns"/>
    <rule ref="category/java/design.xml/SimplifyConditional"/>
    <rule ref="category/java/design.xml/CollapsibleIfStatements"/>
    <rule ref="category/java/design.xml/UselessOverridingMethod"/>
    <rule ref="category/java/design.xml/SingularField"/>
    <rule ref="category/java/design.xml/FinalFieldCouldBeStatic"/>
    <rule ref="category/java/design.xml/ImmutableField"/>
    <rule ref="category/java/design.xml/LogicInversion"/>

    <!-- ================================================================ -->
    <!-- multithreading — high-value concurrency traps.                     -->
    <!-- ================================================================ -->
    <rule ref="category/java/multithreading.xml/DoubleCheckedLocking"/>
    <rule ref="category/java/multithreading.xml/AvoidThreadGroup"/>
    <rule ref="category/java/multithreading.xml/DontCallThreadRun"/>
    <rule ref="category/java/multithreading.xml/NonThreadSafeSingleton"/>
    <rule ref="category/java/multithreading.xml/UnsynchronizedStaticFormatter"/>
    <rule ref="category/java/multithreading.xml/UseNotifyAllInsteadOfNotify"/>
    <!-- AvoidUsingVolatile deliberately omitted — volatile is an intentional choice. -->

    <!-- ================================================================ -->
    <!-- codestyle — we skip the bulk of this category (naming, variable
         length, etc.); only pull in rules that catch real mistakes.        -->
    <!-- ================================================================ -->
    <rule ref="category/java/codestyle.xml/UnnecessaryReturn"/>
    <rule ref="category/java/codestyle.xml/UnnecessaryModifier"/>
    <rule ref="category/java/codestyle.xml/UnnecessaryImport"/>
    <rule ref="category/java/codestyle.xml/UnnecessaryBoxing"/>
    <rule ref="category/java/codestyle.xml/UselessParentheses"/>
    <rule ref="category/java/codestyle.xml/UseDiamondOperator"/>
    <rule ref="category/java/codestyle.xml/UseShortArrayInitializer"/>
    <rule ref="category/java/codestyle.xml/EmptyControlStatement"/>

</ruleset>
