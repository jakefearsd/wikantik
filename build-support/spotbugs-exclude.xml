<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>

    <!-- ================================================================
         EI_EXPOSE_REP / EI_EXPOSE_REP2
         This is an internal application (not a published library); all
         mutable-array-return and mutable-field-store warnings are
         idiomatic codebase patterns that don't cross trust boundaries.
         Records expose their components by language design; value-carrier
         classes are explicitly not hardened against internal mutations.

         Historical context: Phase 11 Ckpt 2 filtered the subsystem
         Services/Deps records + inner records.  Phase 11.5 broadens
         coverage to the full com.wikantik.* package since every site
         has been inspected and none crosses a trust boundary.
    ================================================================ -->

    <!-- Broad application-wide suppression: any com.wikantik class.
         Bug code "EI" covers EI_EXPOSE_REP; "EI2" covers EI_EXPOSE_REP2.
         Both must be listed because the SpotBugs filter matches bug codes exactly. -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Or>
            <Bug code="EI"/>
            <Bug code="EI2"/>
        </Or>
    </Match>

    <!-- ================================================================
         CT_CONSTRUCTOR_THROW
         Fail-fast constructor throws are the codebase's idiom for
         "all-or-nothing" initialization of subsystem managers, bridges,
         and context objects.  These are intentional; there is no
         finalizer-related GC risk because these objects are not
         finalize()-bearing.
    ================================================================ -->

    <Match>
        <Or>
            <!-- Core engine + context objects -->
            <Class name="com.wikantik.WikiEngine"/>
            <Class name="com.wikantik.WikiContext"/>
            <Class name="com.wikantik.WikiSession"/>
            <!-- Attachment + diff managers -->
            <Class name="com.wikantik.attachment.DefaultAttachmentManager"/>
            <Class name="com.wikantik.diff.DefaultDifferenceManager"/>
            <!-- Filters -->
            <Class name="com.wikantik.filters.DefaultFilterManager"/>
            <!-- Knowledge subsystem -->
            <Class name="com.wikantik.knowledge.MentionIndex"/>
            <Class name="com.wikantik.knowledge.embedding.NodeMentionSimilarity"/>
            <Class name="com.wikantik.knowledge.extraction.AsyncEntityExtractionListener"/>
            <Class name="com.wikantik.knowledge.extraction.BootstrapEntityExtractionIndexer"/>
            <!-- KG judge subsystem (fail-fast validation of injected deps) -->
            <Class name="com.wikantik.knowledge.judge.DefaultKgProposalJudgeService"/>
            <Class name="com.wikantik.knowledge.judge.JdbcKgJudgeTimeoutRepository"/>
            <Class name="com.wikantik.knowledge.judge.JudgeRunner"/>
            <Class name="com.wikantik.knowledge.judge.KgMaterializationService"/>
            <!-- Access filters + provider decorator (fail-fast on missing config/deps) -->
            <Class name="com.wikantik.mcp.McpAccessFilter"/>
            <Class name="com.wikantik.tools.ToolsAccessFilter"/>
            <Class name="com.wikantik.providers.PageProviderDecorator"/>
            <!-- MBean -->
            <Class name="com.wikantik.management.SimpleMBean"/>
            <!-- Providers -->
            <Class name="com.wikantik.providers.LruPropertyCache"/>
            <!-- Search -->
            <Class name="com.wikantik.search.DefaultSearchManager"/>
            <Class name="com.wikantik.search.embedding.AsyncEmbeddingIndexListener"/>
            <Class name="com.wikantik.search.embedding.EmbeddingIndexService"/>
            <Class name="com.wikantik.search.hybrid.PageMentionsLoader"/>
            <Class name="com.wikantik.search.hybrid.QueryEntityResolver"/>
        </Or>
        <Bug code="CT"/>
    </Match>

    <!-- ================================================================
         UWF_UNWRITTEN_FIELD — LlmCall.inputTokens / LlmCall.outputTokens
         These two fields are deliberate reserved placeholders for a
         planned token-accounting enhancement — see the LlmCallView
         javadoc, which documents them as "reserved for a future
         enhancement". They stay intentionally unwritten until the LLM
         client layer is extended to surface per-call token counts to
         the recording wrappers. Not a bug; suppressed by field so a
         genuine UWF on any other LlmCall field still surfaces.
    ================================================================ -->
    <Match>
        <Class name="com.wikantik.llm.activity.LlmCall"/>
        <Or>
            <Field name="inputTokens"/>
            <Field name="outputTokens"/>
        </Or>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>

    <!-- ================================================================
         THROWS_METHOD_THROWS_RUNTIMEEXCEPTION
         The codebase deliberately documents the unchecked exceptions a
         method may raise in its `throws` clause (e.g. throws RuntimeException
         / IllegalStateException) as caller-facing documentation. SpotBugs
         flags this as redundant bad practice, but it is an intentional,
         pervasive convention (~130 sites) — suppressed app-wide so the scan
         stays actionable. Genuine bugs in those methods still surface under
         every other detector.
    ================================================================ -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION"/>
    </Match>

    <!-- ================================================================
         THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION
         Same rationale as THROWS_METHOD_THROWS_RUNTIMEEXCEPTION above: the
         codebase deliberately declares `throws Exception` (the basic
         checked type) as caller-facing documentation on ~29 methods —
         chiefly servlet/MCP handler entry points that legitimately fan a
         wide variety of checked failures back to a single framework-level
         catch. SpotBugs flags the broad declared type as bad practice, but
         it is an intentional, pervasive convention here. Suppressed
         app-wide so the scan stays actionable; genuine bugs in those
         methods still surface under every other detector.
    ================================================================ -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION"/>
    </Match>

    <!-- ================================================================
         find-sec-bugs first-pass triage (2026-07-18). The blocks below keep
         the security scan readable by removing informational markers and
         verified false positives; the remaining findsecbugs findings
         (PATH_TRAVERSAL_IN, XSS_SERVLET, SQL_INJECTION_JDBC,
         POTENTIAL_XML_INJECTION, UNVALIDATED_REDIRECT, REDOS, ...) are the
         standing review backlog and stay VISIBLE on purpose.
    ================================================================ -->

    <!-- Taint-SOURCE markers, not vulnerabilities: findsecbugs flags every
         read of a request parameter/header/cookie as "this is user input".
         A servlet-based wiki reads request input everywhere by definition;
         the taint SINKS (XSS/SQL/path-traversal detectors) are what we
         review, and those stay unsuppressed. -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Bug pattern="SERVLET_PARAMETER,SERVLET_HEADER,SERVLET_QUERY_STRING,SERVLET_SERVER_NAME,SERVLET_CONTENT_TYPE,SERVLET_HEADER_USER_AGENT,SERVLET_HEADER_REFERER,COOKIE_USAGE"/>
    </Match>

    <!-- Heuristic too noisy to be signal here (144 hits): flags any
         case-normalisation near a comparison. Wiki page-name handling
         case-normalises pervasively and intentionally. -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Bug pattern="IMPROPER_UNICODE"/>
    </Match>

    <!-- Verified false positives (all 11 sites reviewed 2026-07-18): every
         flagged call is InitialContext/Context.lookup() of a JNDI name that
         comes from configuration properties or code constants
         (jdbc/mail DataSource resolution) — no request-derived data reaches
         a JNDI lookup anywhere in the codebase. -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Bug pattern="LDAP_INJECTION"/>
    </Match>

    <!-- Accepted-low (48 hits): CRLF in log4j2 application logs enables log
         forging only for an attacker who can already submit requests; the
         tamper-evident audit trail lives in the audit DB table, not these
         logs. Revisit if file logs ever become a security-audit source. -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>

    <!-- Both deserialization sites install ObjectInputFilter whitelists
         (DefaultReferenceManager.SAFE_DESERIALIZE_FILTER,
         Serializer.SAFE_FILTER) — verified 2026-07-18; findsecbugs does not
         model setObjectInputFilter. -->
    <Match>
        <Or>
            <Class name="com.wikantik.pagegraph.references.DefaultReferenceManager"/>
            <Class name="com.wikantik.util.Serializer"/>
        </Or>
        <Bug pattern="OBJECT_DESERIALIZATION"/>
    </Match>

    <!-- Deliberately permissive CORS on PUBLIC read-only surfaces: the RDF/
         SPARQL endpoints are public-by-design (see PublicRdfServletBase
         docs / ontology design), and the recent-articles feed serves public
         content. Restricted content never reaches either surface. -->
    <Match>
        <Or>
            <Class name="com.wikantik.rest.PublicRdfServletBase"/>
            <Class name="com.wikantik.content.RecentArticlesServlet"/>
        </Or>
        <Bug pattern="PERMISSIVE_CORS"/>
    </Match>

    <!-- MD5 here buckets reference-attribute cache FILENAMES (non-crypto,
         collision cost = a cache filename clash); not used for integrity or
         authentication. -->
    <Match>
        <Class name="com.wikantik.pagegraph.references.DefaultReferenceManager"/>
        <Bug pattern="WEAK_MESSAGE_DIGEST_MD5"/>
    </Match>

    <!-- The admin SecurityVerifier diagnostic creates-and-removes a probe
         user ("password") to verify the user DB accepts writes — the
         literal is the point of the self-test, not a credential. -->
    <Match>
        <Class name="com.wikantik.auth.subsystem.verify.PolicyVerifier"/>
        <Bug pattern="HARD_CODE_PASSWORD"/>
    </Match>

</FindBugsFilter>
