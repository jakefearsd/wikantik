<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>

    <!-- ================================================================
         EI_EXPOSE_REP / EI_EXPOSE_REP2
         This is an internal application (not a published library); all
         mutable-array-return and mutable-field-store warnings are
         idiomatic codebase patterns that don't cross trust boundaries.
         Records expose their components by language design; value-carrier
         classes are explicitly not hardened against internal mutations.

         Historical context: Phase 11 Ckpt 2 filtered the subsystem
         Services/Deps records + inner records.  Phase 11.5 broadens
         coverage to the full com.wikantik.* package since every site
         has been inspected and none crosses a trust boundary.
    ================================================================ -->

    <!-- Broad application-wide suppression: any com.wikantik class.
         Bug code "EI" covers EI_EXPOSE_REP; "EI2" covers EI_EXPOSE_REP2.
         Both must be listed because the SpotBugs filter matches bug codes exactly. -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Or>
            <Bug code="EI"/>
            <Bug code="EI2"/>
        </Or>
    </Match>

    <!-- ================================================================
         CT_CONSTRUCTOR_THROW
         Fail-fast constructor throws are the codebase's idiom for
         "all-or-nothing" initialization of subsystem managers, bridges,
         and context objects.  These are intentional; there is no
         finalizer-related GC risk because these objects are not
         finalize()-bearing.
    ================================================================ -->

    <Match>
        <Or>
            <!-- Core engine + context objects -->
            <Class name="com.wikantik.WikiEngine"/>
            <Class name="com.wikantik.WikiContext"/>
            <Class name="com.wikantik.WikiSession"/>
            <!-- Attachment + diff managers -->
            <Class name="com.wikantik.attachment.DefaultAttachmentManager"/>
            <Class name="com.wikantik.diff.DefaultDifferenceManager"/>
            <!-- Filters -->
            <Class name="com.wikantik.filters.DefaultFilterManager"/>
            <!-- Knowledge subsystem -->
            <Class name="com.wikantik.knowledge.MentionIndex"/>
            <Class name="com.wikantik.knowledge.embedding.NodeMentionSimilarity"/>
            <Class name="com.wikantik.knowledge.extraction.AsyncEntityExtractionListener"/>
            <Class name="com.wikantik.knowledge.extraction.BootstrapEntityExtractionIndexer"/>
            <!-- MBean -->
            <Class name="com.wikantik.management.SimpleMBean"/>
            <!-- Providers -->
            <Class name="com.wikantik.providers.LruPropertyCache"/>
            <!-- Search -->
            <Class name="com.wikantik.search.DefaultSearchManager"/>
            <Class name="com.wikantik.search.embedding.AsyncEmbeddingIndexListener"/>
            <Class name="com.wikantik.search.embedding.EmbeddingIndexService"/>
            <Class name="com.wikantik.search.hybrid.PageMentionsLoader"/>
            <Class name="com.wikantik.search.hybrid.QueryEntityResolver"/>
        </Or>
        <Bug code="CT"/>
    </Match>

    <!-- ================================================================
         UWF_UNWRITTEN_FIELD — LlmCall.inputTokens / LlmCall.outputTokens
         These two fields are deliberate reserved placeholders for a
         planned token-accounting enhancement — see the LlmCallView
         javadoc, which documents them as "reserved for a future
         enhancement". They stay intentionally unwritten until the LLM
         client layer is extended to surface per-call token counts to
         the recording wrappers. Not a bug; suppressed by field so a
         genuine UWF on any other LlmCall field still surfaces.
    ================================================================ -->
    <Match>
        <Class name="com.wikantik.llm.activity.LlmCall"/>
        <Or>
            <Field name="inputTokens"/>
            <Field name="outputTokens"/>
        </Or>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>

    <!-- ================================================================
         THROWS_METHOD_THROWS_RUNTIMEEXCEPTION
         The codebase deliberately documents the unchecked exceptions a
         method may raise in its `throws` clause (e.g. throws RuntimeException
         / IllegalStateException) as caller-facing documentation. SpotBugs
         flags this as redundant bad practice, but it is an intentional,
         pervasive convention (~130 sites) — suppressed app-wide so the scan
         stays actionable. Genuine bugs in those methods still surface under
         every other detector.
    ================================================================ -->
    <Match>
        <Class name="~com\.wikantik\..*"/>
        <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION"/>
    </Match>

</FindBugsFilter>
