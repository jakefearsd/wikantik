{
  "uid": "wikantik-host",
  "title": "Wikantik — Host & Infra",
  "tags": ["wikantik"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row", "id": 1, "title": "Scrape health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat", "id": 2, "title": "Targets up",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "up", "legendFormat": "{{job}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "textMode": "auto", "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "type": "row", "id": 10, "title": "Host",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries", "id": 11, "title": "CPU utilisation",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        { "refId": "A", "expr": "1 - avg(rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\"}[5m]))", "legendFormat": "cpu util",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries", "id": 12, "title": "Load average",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        { "refId": "A", "expr": "node_load1{job=\"node\"}", "legendFormat": "1m",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "node_load5{job=\"node\"}", "legendFormat": "5m",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "C", "expr": "node_load15{job=\"node\"}", "legendFormat": "15m",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 13, "title": "Memory",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [
        { "refId": "A", "expr": "node_memory_MemTotal_bytes{job=\"node\"}", "legendFormat": "total",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "node_memory_MemTotal_bytes{job=\"node\"} - node_memory_MemAvailable_bytes{job=\"node\"}", "legendFormat": "used",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 14, "title": "Disk I/O throughput",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [
        { "refId": "A", "expr": "rate(node_disk_read_bytes_total{job=\"node\"}[5m])", "legendFormat": "read {{device}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "rate(node_disk_written_bytes_total{job=\"node\"}[5m])", "legendFormat": "write {{device}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 15, "title": "Disk space used",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        { "refId": "A", "expr": "1 - (node_filesystem_avail_bytes{job=\"node\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=\"node\",fstype!~\"tmpfs|overlay\"})", "legendFormat": "{{mountpoint}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 16, "title": "Network throughput",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "targets": [
        { "refId": "A", "expr": "rate(node_network_receive_bytes_total{job=\"node\",device!=\"lo\"}[5m])", "legendFormat": "rx {{device}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "rate(node_network_transmit_bytes_total{job=\"node\",device!=\"lo\"}[5m])", "legendFormat": "tx {{device}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 17, "title": "Open file descriptors",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "targets": [
        { "refId": "A", "expr": "node_filefd_allocated{job=\"node\"}", "legendFormat": "open fds",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "row", "id": 20, "title": "Containers",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 }
    },
    {
      "type": "timeseries", "id": 21, "title": "Container CPU (cores)",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\",name=~\".+\"}[5m]))", "legendFormat": "{{name}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 22, "title": "Container memory",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "targets": [
        { "refId": "A", "expr": "container_memory_working_set_bytes{job=\"cadvisor\",name=~\".+\"}", "legendFormat": "{{name}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 23, "title": "Container network",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_network_receive_bytes_total{job=\"cadvisor\",name=~\".+\"}[5m]))", "legendFormat": "rx {{name}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "sum by (name) (rate(container_network_transmit_bytes_total{job=\"cadvisor\",name=~\".+\"}[5m]))", "legendFormat": "tx {{name}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 24, "title": "Container block I/O",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_fs_writes_bytes_total{job=\"cadvisor\",name=~\".+\"}[5m]))", "legendFormat": "{{name}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "row", "id": 30, "title": "PostgreSQL",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 59 }
    },
    {
      "type": "timeseries", "id": 31, "title": "Connections",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 60 },
      "targets": [
        { "refId": "A", "expr": "sum(pg_stat_activity_count{job=\"postgres\"})", "legendFormat": "current",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "pg_settings_max_connections{job=\"postgres\"}", "legendFormat": "max",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 32, "title": "Transaction rate",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 60 },
      "targets": [
        { "refId": "A", "expr": "rate(pg_stat_database_xact_commit{job=\"postgres\",datname=\"wikantik\"}[5m])", "legendFormat": "commit",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "rate(pg_stat_database_xact_rollback{job=\"postgres\",datname=\"wikantik\"}[5m])", "legendFormat": "rollback",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 33, "title": "Cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 68 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(pg_stat_database_blks_hit{job=\"postgres\",datname=\"wikantik\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{job=\"postgres\",datname=\"wikantik\"}[5m])) + sum(rate(pg_stat_database_blks_read{job=\"postgres\",datname=\"wikantik\"}[5m])))", "legendFormat": "cache hit ratio",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries", "id": 34, "title": "Deadlocks",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 68 },
      "targets": [
        { "refId": "A", "expr": "rate(pg_stat_database_deadlocks{job=\"postgres\",datname=\"wikantik\"}[5m])", "legendFormat": "deadlocks",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries", "id": 35, "title": "Database size",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 76 },
      "targets": [
        { "refId": "A", "expr": "pg_database_size_bytes{job=\"postgres\",datname=\"wikantik\"}", "legendFormat": "db size",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "row", "id": 40, "title": "Hybrid / Vector search",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 84 }
    },
    {
      "type": "timeseries", "id": 41, "title": "Embedding table size",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 85 },
      "targets": [
        { "refId": "A", "expr": "wikantik_pg_table_io_total_bytes{job=\"postgres\",relname=~\".*embedding.*|kg_content_chunks\"}", "legendFormat": "{{relname}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 42, "title": "Embedding table cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 85 },
      "targets": [
        { "refId": "A", "expr": "rate(wikantik_pg_table_io_heap_blks_hit{job=\"postgres\",relname=~\".*embedding.*|kg_content_chunks\"}[5m]) / (rate(wikantik_pg_table_io_heap_blks_hit{job=\"postgres\",relname=~\".*embedding.*|kg_content_chunks\"}[5m]) + rate(wikantik_pg_table_io_heap_blks_read{job=\"postgres\",relname=~\".*embedding.*|kg_content_chunks\"}[5m]))", "legendFormat": "{{relname}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 43, "title": "Query embedder calls",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 93 },
      "targets": [
        { "refId": "A", "expr": "sum by (result) (rate(wikantik_search_hybrid_embedder_calls_total{job=\"wikantik\"}[5m]))", "legendFormat": "{{result}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 44, "title": "Embedder circuit state",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 93 },
      "targets": [
        { "refId": "A", "expr": "wikantik_search_hybrid_embedder_circuit_state{job=\"wikantik\"}", "legendFormat": "circuit state",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "single" } }
    }
  ]
}
