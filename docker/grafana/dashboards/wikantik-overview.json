{
  "uid": "wikantik-overview",
  "title": "Wikantik — Overview",
  "tags": ["wikantik"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row", "id": 1, "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat", "id": 2, "title": "App scrape",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "up{job=\"wikantik\"}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "textMode": "auto", "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat", "id": 3, "title": "Heap used",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(jvm_memory_used_bytes{job=\"wikantik\",area=\"heap\"})",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "type": "stat", "id": 4, "title": "Requests / s",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count{job=\"wikantik\"}[5m]))",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] }
    },
    {
      "type": "stat", "id": 5, "title": "HTTP 5xx / s",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count{job=\"wikantik\",status=~\"5..\"}[5m]))",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "textMode": "auto", "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "decimals": 3,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "row", "id": 10, "title": "JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "timeseries", "id": 11, "title": "JVM heap memory",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "sum(jvm_memory_used_bytes{job=\"wikantik\",area=\"heap\"})", "legendFormat": "used",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "sum(jvm_memory_committed_bytes{job=\"wikantik\",area=\"heap\"})", "legendFormat": "committed",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 12, "title": "GC pause time (rate)",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "sum by (action) (rate(jvm_gc_pause_seconds_sum{job=\"wikantik\"}[5m]))", "legendFormat": "{{action}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 13, "title": "JVM threads",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "refId": "A", "expr": "jvm_threads_live_threads{job=\"wikantik\"}", "legendFormat": "live",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "jvm_threads_daemon_threads{job=\"wikantik\"}", "legendFormat": "daemon",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "C", "expr": "jvm_threads_peak_threads{job=\"wikantik\"}", "legendFormat": "peak",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 14, "title": "Loaded classes",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "refId": "A", "expr": "jvm_classes_loaded_classes{job=\"wikantik\"}", "legendFormat": "loaded",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "row", "id": 20, "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "timeseries", "id": 21, "title": "Request rate by status",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "targets": [
        { "refId": "A", "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"wikantik\"}[5m]))", "legendFormat": "{{status}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 22, "title": "Avg request latency by URI",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "targets": [
        { "refId": "A", "expr": "sum by (uri) (rate(http_server_requests_seconds_sum{job=\"wikantik\"}[5m])) / sum by (uri) (rate(http_server_requests_seconds_count{job=\"wikantik\"}[5m]))", "legendFormat": "{{uri}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "row", "id": 30, "title": "Wikantik",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }
    },
    {
      "type": "timeseries", "id": 31, "title": "Page activity",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "refId": "A", "expr": "rate(wikantik_page_views_total{job=\"wikantik\"}[5m])", "legendFormat": "views",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "rate(wikantik_page_edits_total{job=\"wikantik\"}[5m])", "legendFormat": "edits",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "C", "expr": "rate(wikantik_page_deletes_total{job=\"wikantik\"}[5m])", "legendFormat": "deletes",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "D", "expr": "rate(wikantik_auth_logins_total{job=\"wikantik\"}[5m])", "legendFormat": "logins",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 32, "title": "Structural index",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        { "refId": "A", "expr": "wikantik_structural_index_pages{job=\"wikantik\"}", "legendFormat": "pages",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "wikantik_structural_index_clusters{job=\"wikantik\"}", "legendFormat": "clusters",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "C", "expr": "wikantik_structural_index_tags{job=\"wikantik\"}", "legendFormat": "tags",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "D", "expr": "wikantik_structural_index_unclaimed{job=\"wikantik\"}", "legendFormat": "unclaimed",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 33, "title": "Hybrid retrieval",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        { "refId": "A", "expr": "wikantik_search_hybrid_vector_index_size{job=\"wikantik\"}", "legendFormat": "vector index size",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "rate(wikantik_search_hybrid_embedder_calls_total{job=\"wikantik\"}[5m])", "legendFormat": "embedder calls/s",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "C", "expr": "wikantik_search_hybrid_embedder_circuit_state{job=\"wikantik\"}", "legendFormat": "circuit state",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries", "id": 34, "title": "Agent projection & tool requests",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        { "refId": "A", "expr": "rate(wikantik_tools_requests_total{job=\"wikantik\"}[5m])", "legendFormat": "tool requests/s",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } },
        { "refId": "B", "expr": "rate(wikantik_for_agent_response_bytes_count{job=\"wikantik\"}[5m])", "legendFormat": "for-agent projections/s",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "row", "id": 40, "title": "Agent & HTTP traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 }
    },
    {
      "type": "timeseries", "id": 41, "title": "Searches / s",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count{job=\"wikantik\",uri=\"/api/search\"}[5m]))", "legendFormat": "searches/s",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries", "id": 42, "title": "Agent & admin traffic by endpoint",
      "description": "MCP, OpenAPI tool server, and admin HTTP request rate. Requires the RequestMetricsFilter coverage added in 2.0.1+.",
      "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "targets": [
        { "refId": "A", "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"wikantik\",uri=~\"(/wikantik-admin-mcp|/knowledge-mcp|/tools|/admin).*\"}[5m]))", "legendFormat": "{{uri}}",
          "datasource": { "type": "prometheus", "uid": "wikantik-prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi" } }
    }
  ]
}
