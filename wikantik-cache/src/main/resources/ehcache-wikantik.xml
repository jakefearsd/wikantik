<config
    xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
    xmlns='http://www.ehcache.org/v3'
    xsi:schemaLocation="http://www.ehcache.org/v3 http://www.ehcache.org/schema/ehcache-core.xsd">

    <!--
        EhCache 3.x Configuration for Wikantik

        Each cache is configured with:
        - expiry: Time-to-live for cache entries (default 60 seconds)
        - heap: Maximum number of entries to store on heap

        The TTL ensures that external file modifications (not through Wikantik UI)
        are detected within the expiry period. Adjust as needed for your use case.

        Key types: java.io.Serializable
        Value types: java.lang.Object
    -->

    <!-- Rendering cache for rendered wiki content -->
    <cache alias="wikantik.renderingCache">
        <key-type>java.io.Serializable</key-type>
        <value-type>java.lang.Object</value-type>
        <expiry>
            <ttl unit="seconds">60</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <!-- Page metadata cache -->
    <cache alias="wikantik.pageCache">
        <key-type>java.io.Serializable</key-type>
        <value-type>java.lang.Object</value-type>
        <expiry>
            <ttl unit="seconds">60</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <!-- Page text content cache -->
    <cache alias="wikantik.pageTextCache">
        <key-type>java.io.Serializable</key-type>
        <value-type>java.lang.Object</value-type>
        <expiry>
            <ttl unit="seconds">60</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <!-- Page version history cache -->
    <cache alias="wikantik.pageHistoryCache">
        <key-type>java.io.Serializable</key-type>
        <value-type>java.lang.Object</value-type>
        <expiry>
            <ttl unit="seconds">60</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <!-- Attachment metadata cache -->
    <cache alias="wikantik.attachmentsCache">
        <key-type>java.io.Serializable</key-type>
        <value-type>java.lang.Object</value-type>
        <expiry>
            <ttl unit="seconds">60</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <!-- Attachment collections cache -->
    <cache alias="wikantik.attachmentCollectionsCache">
        <key-type>java.io.Serializable</key-type>
        <value-type>java.lang.Object</value-type>
        <expiry>
            <ttl unit="seconds">60</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <!-- Dynamic attachment cache -->
    <cache alias="wikantik.dynamicAttachmentCache">
        <key-type>java.io.Serializable</key-type>
        <value-type>java.lang.Object</value-type>
        <expiry>
            <ttl unit="seconds">60</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

</config>
