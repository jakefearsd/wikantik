<?xml version="1.0" encoding="UTF-8"?>
<!--
  CLI logging config: everything to stdout, INFO for wikantik code, WARN
  elsewhere so the Ollama / Anthropic HTTP client libraries don't flood the
  terminal with connection chatter. The %msg pattern is chosen so piping the
  output through grep "Bootstrap extraction:" works without surprises.
-->
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5level %logger{1.} - %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Logger name="com.wikantik" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Root level="WARN">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
