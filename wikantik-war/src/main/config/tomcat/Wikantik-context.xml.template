<!--
  Wikantik Context Configuration for PostgreSQL

  This file is copied by deploy-local.sh to:
    tomcat/tomcat-11/conf/Catalina/localhost/Wikantik.xml

  IMPORTANT: After copying, edit the file to replace YOUR_SECURE_PASSWORD_HERE
  with your actual PostgreSQL password for the 'wikantik' user.
-->
<Context reloadable="true">

    <!-- Single shared JNDI DataSource for all Wikantik subsystems -->
    <Resource name="jdbc/WikiDatabase"
              auth="Container"
              type="javax.sql.DataSource"
              factory="org.apache.tomcat.dbcp.dbcp2.BasicDataSourceFactory"
              driverClassName="org.postgresql.Driver"
              url="jdbc:postgresql://localhost:5432/wikantik"
              username="wikantik"
              password="YOUR_SECURE_PASSWORD_HERE"
              maxTotal="30"
              maxIdle="10"
              maxWaitMillis="10000"
              validationQuery="SELECT 1"
              testOnBorrow="true"/>

</Context>
