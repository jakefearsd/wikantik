<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

   <description>
       Wikantik is an open source wiki engine.  It is licensed
       under the Apache 2.0 license.
       For more information, please come to http://wikantik.com/
   </description>
   <display-name>Wikantik</display-name>

   <!--
      WikiServletFilter sets authentication status based on container credentials
      and cookie authentication. It initialises the WikiSession for each request
      and is required for attachment serving via /attach/*.
   -->

   <!-- Request correlation: generates unique request ID and enriches MDC for all log lines -->
   <filter>
     <filter-name>RequestCorrelationFilter</filter-name>
     <filter-class>com.wikantik.observability.RequestCorrelationFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>RequestCorrelationFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>

   <!-- Internal network guard: restricts observability endpoints to localhost + private networks -->
   <filter>
     <filter-name>InternalNetworkFilter</filter-name>
     <filter-class>com.wikantik.observability.InternalNetworkFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>InternalNetworkFilter</filter-name>
     <url-pattern>/api/health</url-pattern>
     <url-pattern>/metrics</url-pattern>
   </filter-mapping>

   <!-- Request metrics: records HTTP request duration for Prometheus -->
   <filter>
     <filter-name>RequestMetricsFilter</filter-name>
     <filter-class>com.wikantik.observability.RequestMetricsFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>RequestMetricsFilter</filter-name>
     <url-pattern>/api/*</url-pattern>
     <url-pattern>/wiki/*</url-pattern>
   </filter-mapping>

   <!-- Admin authorization: enforces AllPermission on /admin/* endpoints -->
   <filter>
     <filter-name>AdminAuthFilter</filter-name>
     <filter-class>com.wikantik.rest.AdminAuthFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>AdminAuthFilter</filter-name>
     <url-pattern>/admin/*</url-pattern>
   </filter-mapping>

   <!-- React SPA routing: forwards known SPA paths to /index.html for client-side routing -->
   <filter>
     <filter-name>SpaRoutingFilter</filter-name>
     <filter-class>com.wikantik.rest.SpaRoutingFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>SpaRoutingFilter</filter-name>
     <url-pattern>/wiki/*</url-pattern>
     <url-pattern>/edit/*</url-pattern>
     <url-pattern>/diff/*</url-pattern>
     <url-pattern>/admin/*</url-pattern>
     <url-pattern>/search</url-pattern>
     <url-pattern>/preferences</url-pattern>
     <url-pattern>/reset-password</url-pattern>
     <url-pattern>/</url-pattern>
   </filter-mapping>

   <filter>
     <filter-name>WikiServletFilter</filter-name>
     <filter-class>com.wikantik.ui.WikiServletFilter</filter-class>
   </filter>

   <filter-mapping>
     <filter-name>WikiServletFilter</filter-name>
     <url-pattern>/attach/*</url-pattern>
   </filter-mapping>
   <!-- optional set of servlet filters which inject OWASP recommended
    http response headers into all outbound responses.
    most have optional init parameters that can be used to customize the output
   -->
   <filter>
     <filter-name>COEPFilter</filter-name>
     <filter-class>com.wikantik.http.filter.COEPFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>COEPFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>CORPFilter</filter-name>
     <filter-class>com.wikantik.http.filter.CORPFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>CORPFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>ClearSiteDataFilter</filter-name>
     <filter-class>com.wikantik.http.filter.ClearSiteDataFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>ClearSiteDataFilter</filter-name>
     <!-- Only clear site data on logout, not all requests -->
     <url-pattern>/api/auth/logout</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>ContentTypeOptionsFilter</filter-name>
     <filter-class>com.wikantik.http.filter.ContentTypeOptionsFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>ContentTypeOptionsFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>CrossDomainFilter</filter-name>
     <filter-class>com.wikantik.http.filter.CrossDomainFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>CrossDomainFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>ReferrerPolicyFilter</filter-name>
     <filter-class>com.wikantik.http.filter.ReferrerPolicyFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>ReferrerPolicyFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
    <filter>
     <filter-name>STSFilter</filter-name>
     <filter-class>com.wikantik.http.filter.STSFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>STSFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>

   <session-config>
       <session-timeout>60</session-timeout>
   </session-config>
   <!--
       HttpSessionListener used for managing WikiSession's.
     -->
   <listener>
      <listener-class>com.wikantik.auth.SessionMonitor</listener-class>
   </listener>

   <!-- servlet context listener to configure API's SPI -->
   <listener>
       <listener-class>com.wikantik.bootstrap.WikiBootstrapServletContextListener</listener-class>
   </listener>

   <!-- MCP server bootstrap â must come after WikiBootstrapServletContextListener -->
   <listener>
       <listener-class>com.wikantik.mcp.McpServerInitializer</listener-class>
   </listener>


   <!--
       Attachment exchange handler.
     -->

   <servlet>
       <servlet-name>AttachmentServlet</servlet-name>
       <servlet-class>com.wikantik.attachment.AttachmentServlet</servlet-class>
   </servlet>

   <!-- Sitemap servlet for search engine indexing -->
   <servlet>
       <servlet-name>SitemapServlet</servlet-name>
       <servlet-class>com.wikantik.ui.SitemapServlet</servlet-class>
   </servlet>

   <!-- REST API servlet for recent articles -->
   <servlet>
       <servlet-name>RecentArticlesServlet</servlet-name>
       <servlet-class>com.wikantik.content.RecentArticlesServlet</servlet-class>
   </servlet>

   <!-- Atom feed servlet for syndication -->
   <servlet>
       <servlet-name>AtomFeedServlet</servlet-name>
       <servlet-class>com.wikantik.content.AtomFeedServlet</servlet-class>
   </servlet>

   <!-- REST API -->
   <servlet>
       <servlet-name>PageResource</servlet-name>
       <servlet-class>com.wikantik.rest.PageResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>PageListResource</servlet-name>
       <servlet-class>com.wikantik.rest.PageListResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>AuthResource</servlet-name>
       <servlet-class>com.wikantik.rest.AuthResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>SearchResource</servlet-name>
       <servlet-class>com.wikantik.rest.SearchResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>HistoryResource</servlet-name>
       <servlet-class>com.wikantik.rest.HistoryResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>BacklinksResource</servlet-name>
       <servlet-class>com.wikantik.rest.BacklinksResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>AttachmentResource</servlet-name>
       <servlet-class>com.wikantik.rest.AttachmentResource</servlet-class>
       <multipart-config>
           <max-file-size>52428800</max-file-size>
           <max-request-size>52428800</max-request-size>
       </multipart-config>
   </servlet>
   <servlet>
       <servlet-name>DiffResource</servlet-name>
       <servlet-class>com.wikantik.rest.DiffResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>RecentChangesResource</servlet-name>
       <servlet-class>com.wikantik.rest.RecentChangesResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>OutboundLinksResource</servlet-name>
       <servlet-class>com.wikantik.rest.OutboundLinksResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>CommentResource</servlet-name>
       <servlet-class>com.wikantik.rest.CommentResource</servlet-class>
   </servlet>

   <!-- Admin API -->
   <servlet>
       <servlet-name>AdminUserResource</servlet-name>
       <servlet-class>com.wikantik.rest.AdminUserResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>AdminContentResource</servlet-name>
       <servlet-class>com.wikantik.rest.AdminContentResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>AdminGroupResource</servlet-name>
       <servlet-class>com.wikantik.rest.AdminGroupResource</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>AdminPolicyResource</servlet-name>
       <servlet-class>com.wikantik.rest.AdminPolicyResource</servlet-class>
   </servlet>

   <!-- Observability -->
   <servlet>
       <servlet-name>HealthServlet</servlet-name>
       <servlet-class>com.wikantik.observability.HealthServlet</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>MetricsServlet</servlet-name>
       <servlet-class>com.wikantik.observability.MetricsServlet</servlet-class>
   </servlet>

   <!-- SSO servlets for OIDC/SAML authentication -->
   <servlet>
       <servlet-name>SSORedirectServlet</servlet-name>
       <servlet-class>com.wikantik.auth.sso.SSORedirectServlet</servlet-class>
   </servlet>
   <servlet>
       <servlet-name>SSOCallbackServlet</servlet-name>
       <servlet-class>com.wikantik.auth.sso.SSOCallbackServlet</servlet-class>
   </servlet>

   <servlet-mapping>
       <servlet-name>SSORedirectServlet</servlet-name>
       <url-pattern>/sso/login</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>SSOCallbackServlet</servlet-name>
       <url-pattern>/sso/callback</url-pattern>
   </servlet-mapping>

   <servlet-mapping>
       <servlet-name>AttachmentServlet</servlet-name>
       <url-pattern>/attach/*</url-pattern>
   </servlet-mapping>

   <servlet-mapping>
       <servlet-name>SitemapServlet</servlet-name>
       <url-pattern>/sitemap.xml</url-pattern>
   </servlet-mapping>

   <servlet-mapping>
       <servlet-name>RecentArticlesServlet</servlet-name>
       <url-pattern>/api/recent-articles</url-pattern>
   </servlet-mapping>

   <servlet-mapping>
       <servlet-name>AtomFeedServlet</servlet-name>
       <url-pattern>/feed.xml</url-pattern>
   </servlet-mapping>

   <servlet-mapping>
       <servlet-name>PageResource</servlet-name>
       <url-pattern>/api/pages/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>PageListResource</servlet-name>
       <url-pattern>/api/pages</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AuthResource</servlet-name>
       <url-pattern>/api/auth/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>SearchResource</servlet-name>
       <url-pattern>/api/search</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>HistoryResource</servlet-name>
       <url-pattern>/api/history/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>BacklinksResource</servlet-name>
       <url-pattern>/api/backlinks/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AttachmentResource</servlet-name>
       <url-pattern>/api/attachments/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>DiffResource</servlet-name>
       <url-pattern>/api/diff/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>RecentChangesResource</servlet-name>
       <url-pattern>/api/recent-changes</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>OutboundLinksResource</servlet-name>
       <url-pattern>/api/outbound-links/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>CommentResource</servlet-name>
       <url-pattern>/api/comments/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AdminUserResource</servlet-name>
       <url-pattern>/admin/users/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AdminUserResource</servlet-name>
       <url-pattern>/admin/users</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AdminContentResource</servlet-name>
       <url-pattern>/admin/content/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AdminGroupResource</servlet-name>
       <url-pattern>/admin/groups/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AdminGroupResource</servlet-name>
       <url-pattern>/admin/groups</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AdminPolicyResource</servlet-name>
       <url-pattern>/admin/policy/*</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>AdminPolicyResource</servlet-name>
       <url-pattern>/admin/policy</url-pattern>
   </servlet-mapping>

   <servlet-mapping>
       <servlet-name>HealthServlet</servlet-name>
       <url-pattern>/api/health</url-pattern>
   </servlet-mapping>
   <servlet-mapping>
       <servlet-name>MetricsServlet</servlet-name>
       <url-pattern>/metrics</url-pattern>
   </servlet-mapping>

   <!-- Error pages -->
   <error-page>
     <error-code>403</error-code>
     <location>/error/Forbidden.html</location>
   </error-page>

   <!-- Require TLS across the board (set to CONFIDENTIAL for production) -->
   <security-constraint>
       <web-resource-collection>
           <web-resource-name>All</web-resource-name>
           <url-pattern>/*</url-pattern>
       </web-resource-collection>
       <user-data-constraint>
           <transport-guarantee>NONE</transport-guarantee>
       </user-data-constraint>
   </security-constraint>

</web-app>
