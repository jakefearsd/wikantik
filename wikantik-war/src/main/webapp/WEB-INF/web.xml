<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

   <description>
       Wikantik is an open source wiki engine.  It is licensed
       under the Apache 2.0 license.
       For more information, please come to http://wikantik.com/
   </description>
   <display-name>Wikantik</display-name>

   <!--
      WikiServletFilter sets authentication status based on container credentials
      and cookie authentication. It initialises the WikiSession for each request
      and is required for attachment serving via /attach/*.
   -->

   <!-- Request correlation: generates unique request ID and enriches MDC for all log lines -->
   <filter>
     <filter-name>RequestCorrelationFilter</filter-name>
     <filter-class>com.wikantik.observability.RequestCorrelationFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>RequestCorrelationFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>

   <!-- Session-cookie policy guard: logs ERROR (rate-limited) if the JSESSIONID
        cookie is issued with SameSite=Strict or no SameSite, the misconfiguration
        that causes random logouts (browsers withhold the cookie on top-level
        navigations). Outermost so it sees the container's final Set-Cookie. -->
   <filter>
     <filter-name>SessionCookiePolicyFilter</filter-name>
     <filter-class>com.wikantik.http.filter.SessionCookiePolicyFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>SessionCookiePolicyFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>

   <!-- Internal network guard: restricts observability endpoints to localhost + private networks -->
   <filter>
     <filter-name>InternalNetworkFilter</filter-name>
     <filter-class>com.wikantik.observability.InternalNetworkFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>InternalNetworkFilter</filter-name>
     <url-pattern>/api/health</url-pattern>
     <url-pattern>/metrics</url-pattern>
   </filter-mapping>

   <!-- Concurrency-bounded admission control. Capped at WIKANTIK_MAX_INFLIGHT_REQUESTS
        permits (default 700, one notch above the measured-comfortable N=650 sustained
        ceiling). Requests over the cap get an immediate 503 + Retry-After:1 instead
        of queueing for up to 60 s. /api/health and /metrics are exempted internally
        in the filter so jakemon never sees a 503 for those. Ordered after correlation
        (so rejected requests still get a request-id in the access log) but before any
        expensive filter or servlet work â no point spending CPU on a request we're
        about to reject. -->
   <filter>
     <filter-name>BackpressureFilter</filter-name>
     <filter-class>com.wikantik.observability.BackpressureFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>BackpressureFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>

   <!-- Request metrics: records HTTP request duration for Prometheus -->
   <filter>
     <filter-name>RequestMetricsFilter</filter-name>
     <filter-class>com.wikantik.observability.RequestMetricsFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>RequestMetricsFilter</filter-name>
     <url-pattern>/api/*</url-pattern>
     <url-pattern>/wiki/*</url-pattern>
     <url-pattern>/admin/*</url-pattern>
     <url-pattern>/tools/*</url-pattern>
     <url-pattern>/wikantik-admin-mcp</url-pattern>
     <url-pattern>/wikantik-admin-mcp/*</url-pattern>
     <url-pattern>/knowledge-mcp</url-pattern>
     <url-pattern>/knowledge-mcp/*</url-pattern>
   </filter-mapping>

   <!-- Per-client-IP rate limiting for the public HTTP surface. Two tiers:
        default (25/s per client) on everything mapped below; expensive
        (3/s per client + 10/s global) on /api/bundle, /api/search, /sparql â
        the endpoints that do per-request embedding inference / heavy query
        work. Loopback + /api/health always exempt. Runs after
        RequestMetricsFilter (429s get measured) and before the auth filters
        (reject cheaply before any auth/DB work). Tune via WIKANTIK_RATELIMIT_*
        env vars; see docs/superpowers/specs/2026-07-02-api-rate-limiting-design.md -->
   <filter>
     <filter-name>RateLimitFilter</filter-name>
     <filter-class>com.wikantik.observability.RateLimitFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>RateLimitFilter</filter-name>
     <url-pattern>/api/*</url-pattern>
     <url-pattern>/id/*</url-pattern>
     <url-pattern>/export/*</url-pattern>
     <url-pattern>/sparql</url-pattern>
   </filter-mapping>

   <!-- HTTP Basic authentication: converts Authorization: Basic headers into
        real wiki logins so automation (curl, CI, scripts) can exercise /api/*
        and /admin/* endpoints as an authenticated principal. No Authorization
        header â pass through. Must run before AdminAuthFilter so the session
        is authenticated before AllPermission is checked. -->
   <filter>
     <filter-name>BasicAuthFilter</filter-name>
     <filter-class>com.wikantik.rest.BasicAuthFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>BasicAuthFilter</filter-name>
     <url-pattern>/api/*</url-pattern>
     <url-pattern>/admin/*</url-pattern>
   </filter-mapping>

   <!-- Remember-me re-auth: when cookie authentication is enabled and the request
        carries a remember-me cookie but the server session is gone (restart/timeout),
        re-establish the authenticated session from the cookie. Runs after BasicAuth
        (explicit creds win) and before AdminAuthFilter (so /admin/* is authenticated
        before AllPermission is checked). Anonymous requests (no remember-me cookie)
        are untouched, preserving the no-session-per-anonymous-request behaviour. -->
   <filter>
     <filter-name>RememberMeAuthFilter</filter-name>
     <filter-class>com.wikantik.rest.RememberMeAuthFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>RememberMeAuthFilter</filter-name>
     <url-pattern>/api/*</url-pattern>
     <url-pattern>/admin/*</url-pattern>
   </filter-mapping>

   <!-- Must-change-password gate: blocks authenticated users flagged for a
        forced password reset from all /api/* and /admin/* endpoints except the
        auth surface (/api/auth/*) they need to complete the change. Browser HTML
        navigations (SPA shell loads) pass through. Runs after RememberMeAuthFilter
        so re-authenticated sessions are visible, and before AdminAuthFilter. -->
   <filter>
     <filter-name>MustChangePasswordFilter</filter-name>
     <filter-class>com.wikantik.rest.MustChangePasswordFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>MustChangePasswordFilter</filter-name>
     <url-pattern>/api/*</url-pattern>
     <url-pattern>/admin/*</url-pattern>
   </filter-mapping>

   <!-- Admin authorization: enforces AllPermission on /admin/* endpoints -->
   <filter>
     <filter-name>AdminAuthFilter</filter-name>
     <filter-class>com.wikantik.rest.AdminAuthFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>AdminAuthFilter</filter-name>
     <url-pattern>/admin/*</url-pattern>
   </filter-mapping>

   <!-- SCIM 2.0: bearer-token access filter â must run before SCIM servlet dispatch -->
   <filter>
     <filter-name>ScimAccessFilter</filter-name>
     <filter-class>com.wikantik.scim.ScimAccessFilter</filter-class>
     <init-param>
       <param-name>wikantik.scim.token</param-name>
       <param-value></param-value>
     </init-param>
   </filter>
   <filter-mapping>
     <filter-name>ScimAccessFilter</filter-name>
     <url-pattern>/scim/v2/*</url-pattern>
   </filter-mapping>

   <!-- Cache headers: immutable for hashed assets, no-store for index.html -->
   <filter>
     <filter-name>CacheHeaderFilter</filter-name>
     <filter-class>com.wikantik.http.filter.CacheHeaderFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>CacheHeaderFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>

   <!-- Build version header: lets the SPA detect redeployments -->
   <filter>
     <filter-name>BuildVersionFilter</filter-name>
     <filter-class>com.wikantik.rest.BuildVersionFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>BuildVersionFilter</filter-name>
     <url-pattern>/api/*</url-pattern>
     <url-pattern>/admin/*</url-pattern>
   </filter-mapping>

   <!-- optional set of servlet filters which inject OWASP recommended
    http response headers into all outbound responses.
    most have optional init parameters that can be used to customize the output
   -->
   <filter>
     <filter-name>COEPFilter</filter-name>
     <filter-class>com.wikantik.http.filter.COEPFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>COEPFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>CORPFilter</filter-name>
     <filter-class>com.wikantik.http.filter.CORPFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>CORPFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>ClearSiteDataFilter</filter-name>
     <filter-class>com.wikantik.http.filter.ClearSiteDataFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>ClearSiteDataFilter</filter-name>
     <!-- Only clear site data on logout, not all requests -->
     <url-pattern>/api/auth/logout</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>ContentTypeOptionsFilter</filter-name>
     <filter-class>com.wikantik.http.filter.ContentTypeOptionsFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>ContentTypeOptionsFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <!-- X-Robots-Tag: noindex on the API. /api/pages/ is robots-allowed so Google
        can fetch page content while rendering the SPA, but the JSON itself must
        not be indexed as a standalone URL. Scoped to /api/* so /wiki/ HTML pages
        stay indexable. -->
   <filter>
     <filter-name>XRobotsTagFilter</filter-name>
     <filter-class>com.wikantik.http.filter.XRobotsTagFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>XRobotsTagFilter</filter-name>
     <url-pattern>/api/*</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>CrossDomainFilter</filter-name>
     <filter-class>com.wikantik.http.filter.CrossDomainFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>CrossDomainFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <filter>
     <filter-name>ReferrerPolicyFilter</filter-name>
     <filter-class>com.wikantik.http.filter.ReferrerPolicyFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>ReferrerPolicyFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
    <filter>
     <filter-name>STSFilter</filter-name>
     <filter-class>com.wikantik.http.filter.STSFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>STSFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <!-- Content-Security-Policy: a browser-enforced backstop against XSS, clickjacking, and
        content injection. script-src deliberately keeps 'unsafe-inline' because the SPA shell
        carries an inline stale-asset auto-recovery script AND an inline onclick handler (an
        inline event handler cannot be nonce'd, so a strict script-src would break the app); the
        load-bearing wins here are frame-ancestors 'none' (clickjacking), object-src 'none',
        base-uri 'self', and the same-origin default-src. style-src/font-src allow Google Fonts;
        img-src allows data: + https: for wiki-content images; worker-src allows blob: for
        client-side visualisations. Tune the policy via the CSPValue init-param below. -->
   <filter>
     <filter-name>CSPFilter</filter-name>
     <filter-class>com.wikantik.http.filter.CSPFilter</filter-class>
     <async-supported>true</async-supported>
     <init-param>
       <param-name>CSPValue</param-name>
       <param-value>default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'</param-value>
     </init-param>
   </filter>
   <filter-mapping>
     <filter-name>CSPFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>
   <!-- X-Frame-Options: DENY â legacy-browser clickjacking defense. Modern browsers honor the
        CSP frame-ancestors 'none' directive above; both are shipped for full coverage. -->
   <filter>
     <filter-name>ClickJackFilter</filter-name>
     <filter-class>com.wikantik.http.filter.ClickJackFilter</filter-class>
     <async-supported>true</async-supported>
     <init-param>
       <param-name>mode</param-name>
       <param-value>DENY</param-value>
     </init-param>
   </filter>
   <filter-mapping>
     <filter-name>ClickJackFilter</filter-name>
     <url-pattern>/*</url-pattern>
   </filter-mapping>

   <!-- Content-serving filters run AFTER the /* security-header filters above. SpaRoutingFilter and
        WikiPageFormatFilter serve /wiki/* (and the SPA shell) by writing the response body and then
        returning WITHOUT calling chain.doFilter; if they were ordered before the header filters (as
        they once were), none of the security headers above would reach a server-rendered HTML page.
        Keep this block last in the filter chain. Guarded by SecurityHeaderRegistrationTest
        #securityHeaderFilters_runBeforeChainShortCircuitingContentFilters and SecurityHeadersIT. -->
   <!-- Raw page content: serves /wiki/{slug}?format=md|json for RAG/SEO indexing -->
   <filter>
     <filter-name>WikiPageFormatFilter</filter-name>
     <filter-class>com.wikantik.rest.WikiPageFormatFilter</filter-class>
     <async-supported>true</async-supported>
   </filter>
   <filter-mapping>
     <filter-name>WikiPageFormatFilter</filter-name>
     <url-pattern>/wiki/*</url-pattern>
   </filter-mapping>

   <!-- React SPA routing: forwards known SPA paths to /index.html for client-side routing -->
   <filter>
     <filter-name>SpaRoutingFilter</filter-name>
     <filter-class>com.wikantik.rest.SpaRoutingFilter</filter-class>
   </filter>
   <filter-mapping>
     <filter-name>SpaRoutingFilter</filter-name>
     <url-pattern>/wiki/*</url-pattern>
     <url-pattern>/edit/*</url-pattern>
     <url-pattern>/diff/*</url-pattern>
     <url-pattern>/admin</url-pattern>
     <url-pattern>/admin/*</url-pattern>
     <url-pattern>/search</url-pattern>
     <url-pattern>/graph</url-pattern>
     <url-pattern>/page-graph</url-pattern>
     <url-pattern>/knowledge-graph</url-pattern>
     <url-pattern>/preferences</url-pattern>
     <url-pattern>/me/mentions</url-pattern>
     <url-pattern>/reset-password</url-pattern>
     <url-pattern>/change-password</url-pattern>
     <url-pattern>/login</url-pattern>
     <url-pattern>/blog/*</url-pattern>
     <url-pattern>/blog</url-pattern>
     <url-pattern>/</url-pattern>
   </filter-mapping>

   <filter>
     <filter-name>WikiServletFilter</filter-name>
     <filter-class>com.wikantik.ui.WikiServletFilter</filter-class>
   </filter>

   <filter-mapping>
     <filter-name>WikiServletFilter</filter-name>
     <url-pattern>/attach/*</url-pattern>
   </filter-mapping>

   <session-config>
       <session-timeout>60</session-timeout>
       <!--
         Harden the JSESSIONID cookie:
           * http-only    - never readable from JS, so an XSS cannot exfiltrate it.
           * tracking-mode COOKIE - no URL rewriting fallback (would leak session IDs
                            into logs and referrers).

         The `Secure` attribute is deployment-topology-dependent (HTTPS vs not)
         and intentionally NOT set here. Production deployments running behind
         HTTPS should enable it via Tomcat's per-context CookieProcessor in
         conf/Catalina/localhost/ROOT.xml or via the reverse proxy:

           <CookieProcessor className="org.apache.tomcat.util.http.Rfc6265CookieProcessor"
                            sameSiteCookies="lax"/>
           <Valve className="org.apache.catalina.valves.RemoteIpValve"
                  protocolHeader="X-Forwarded-Proto" />

         Setting <secure>true</secure> in this descriptor caused intermittent
         JSESSIONID drops on http://localhost dev â Chrome's "is localhost a
         secure context for cookies?" check is not 100% reliable across
         versions/extensions, and a single dropped cookie kicks the admin UI
         to anonymous.
       -->
       <cookie-config>
           <http-only>true</http-only>
       </cookie-config>
       <tracking-mode>COOKIE</tracking-mode>
   </session-config>
